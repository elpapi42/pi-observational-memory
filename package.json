{
  "name": "pi-observational-memory",
  "version": "0.1.0",
  "description": "Tiered Observational Memory (TOM) — cache-friendly compaction for pi with raw/observation/reflection tiers.",
  "type": "module",
  "license": "MIT",
  "keywords": ["pi-extension", "compaction", "memory", "llm"],
  "pi": {
    "extensions": ["./src/index.ts"]
