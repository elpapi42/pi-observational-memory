    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
